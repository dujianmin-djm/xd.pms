@page
@using XD.Pms.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using Volo.Abp.Account.Localization
@using Volo.Abp.Account.Settings
@using Volo.Abp.Identity;
@using Volo.Abp.Settings
@model Volo.Abp.Account.Web.Pages.Account.LoginModel
@inject IHtmlLocalizer<AccountResource> L
@inject IHtmlLocalizer<PmsResource> L_Pms
@inject ISettingProvider SettingProvider
@{
    ViewBag.PageName = L["Login"];
}
@section styles
{
    <abp-style src="/Pages/Account/Login.css" />
}
@section scripts
{
    <abp-script src="/Pages/Account/Login.js" />
}

@if (Model.ShowRequireMigrateSeedMessage)
{
    <div class="alert alert-danger">
        <h4 class="alert-heading">@L["RequireMigrateSeedTitle"]</h4>
        <p>@L["RequireMigrateSeedMessage"]</p>
    </div>
}

@if (Model.EnableLocalLogin)
{
    <form id="loginForm" method="post">
        <div class="input-group">
            <span class="input-group-text"><i class="fas fa-user fa-lg"></i></span>
            <input asp-for="LoginInput.UserNameOrEmailAddress" class="form-control" placeholder="@L["UserNameOrEmailAddress"]" />
        </div>
        <div class="mb-2 ms-3rem">
            <span asp-validation-for="LoginInput.UserNameOrEmailAddress"></span>
        </div>

        <div class="input-group">
            <span class="input-group-text"><i class="fas fa-lock fa-lg"></i></span>
            <input type="password" asp-for="LoginInput.Password" class="form-control" autocomplete="new-password" placeholder="@L["Password"]" />
            <i id="showpassicon" class="bi bi-eye-slash show-pass-icon" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-html="true" aria-label="@L_Pms["ShowPassword"]" data-bs-original-title="@L_Pms["ShowPassword"]"></i>
            <i id="capslockicon" class="bi bi-capslock caps-lock-icon" style="display: none;right: 50px;" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-html="true" aria-label="<i class='bi bi-exclamation-circle'></i> @L_Pms["CapsLockon"]" data-bs-original-title="<i class='bi bi-exclamation-circle'></i> @L_Pms["CapsLockon"]"></i>
        </div>
        <div class="mb-3 ms-3rem">
            <span asp-validation-for="LoginInput.Password"></span>
        </div>

        <abp-row class="mb-2">
            <abp-column>
                <abp-input asp-for="LoginInput.RememberMe" />
            </abp-column>
            <abp-column class="text-end">
                <a href="@Url.Page("./ForgotPassword", new { returnUrl = Model.ReturnUrl, returnUrlHash = Model.ReturnUrlHash })" data-bs-toggle="tooltip" data-bs-placement="bottom" title="To Reset Password">@L["ForgotPassword"]</a>
            </abp-column>
        </abp-row>

        <div class="d-grid">
            <abp-button type="submit" button-type="Primary" name="Action" value="Login" class="btn-lg mb-1">
                <i class="bi bi-box-arrow-in-right me-1"></i>@L["Login"]
            </abp-button>
            @if (Model.ShowCancelButton)
            {
                <abp-button type="submit" button-type="Secondary" formnovalidate="formnovalidate" name="Action" value="Cancel" class="btn-lg mb-1">@L["Cancel"]</abp-button>
            }
        </div>
    </form>
}

@if (Model.VisibleExternalProviders.Any())
{
    <div class="mt-2">
        <h5>@L["OrLoginWith"]</h5>
        <form asp-page="./Login" asp-page-handler="ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" asp-route-returnUrlHash="@Model.ReturnUrlHash" method="post">
            @foreach (var provider in Model.VisibleExternalProviders)
            {
                <button type="submit" class="btn btn-primary m-1" name="provider" value="@provider.AuthenticationScheme" title="@L["LogInUsingYourProviderAccount", provider.DisplayName]">@provider.DisplayName</button>
            }
        </form>
    </div>
}

@if (!Model.EnableLocalLogin && !Model.VisibleExternalProviders.Any())
{
    <div class="alert alert-warning">
        <strong>@L["InvalidLoginRequest"]</strong>
        @L["ThereAreNoLoginSchemesConfiguredForThisClient"]
    </div>
}
