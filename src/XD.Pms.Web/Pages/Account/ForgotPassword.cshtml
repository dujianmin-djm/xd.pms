@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Volo.Abp.Account.Localization
@inject IHtmlLocalizer<AccountResource> L
@model Volo.Abp.Account.Web.Pages.Account.ForgotPasswordModel
@{
    ViewBag.PageName = L["ForgotPassword"];
}
<form method="post" class="mt-3">
    <p>@L["SendPasswordResetLink_Information"]</p>
    <div class="form-floating mb-3">
        <input asp-for="Email" class="form-control" placeholder="Email">
        <label asp-for="Email" class="form-label"></label>
        <span asp-validation-for="Email"></span>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="./Login" title="To Login" class="btn btn-outline-primary btn-lg text-nowrap" asp-all-route-data="@(new Dictionary<string, string> {{"returnUrl", Model.ReturnUrl}, {"returnUrlHash", Model.ReturnUrlHash}})">
            <i class="bi bi-arrow-left-short"></i> @L["Login"]
        </a>
        <abp-button button-type="Primary" type="submit" class="btn-lg text-nowrap flex-fill" title="To Submit">
            <i class="bi bi-send me-1"></i> @L["Submit"]
        </abp-button>
    </div>
</form>