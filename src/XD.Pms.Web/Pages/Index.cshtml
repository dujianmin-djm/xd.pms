@page
@model XD.Pms.Web.Pages.IndexModel
@using XD.Pms.Web.Menus
@using Volo.Abp.AspNetCore.Mvc.UI.Layout
@using Microsoft.AspNetCore.Mvc.Localization
@using XD.Pms.Localization
@using Volo.Abp.Users
@inject IPageLayout PageLayout
@inject IHtmlLocalizer<PmsResource> L
@inject ICurrentUser CurrentUser
@{
    ViewBag.PageTitle = L["Home"];
    PageLayout.Content.MenuItemName = PmsMenus.Home;
}

@section styles {
    <abp-style src="/Pages/Index.css" />
}

<div class="lpx-content-height row mb-3">
    <div class="col-xl-6 col-12 d-flex">
        <div class="card h-lg-100 w-100 overflow-hidden">
            <div class="card-body">
                <div class="starting-content pe-5">
                    @if (!CurrentUser.IsAuthenticated)
                    {
                        <h3>@L["Welcome"]</h3>
                        <p class="lead text-muted mb-2">@L["LongWelcomeMessage"]</p>

                        @* 使用本地 Account 控制器触发 OIDC 登录 *@
                        <a href="/Account/Login?returnUrl=@Url.Page("/Index")"
                           class="btn btn-primary mb-4">
                            <i class="fa-solid fa-right-to-bracket me-1"></i>
                            <span>@L["Login"]</span>
                        </a>
                    }
                    else
                    {
                        <h3>@L["Welcome"], @CurrentUser.UserName!</h3>
                        <p class="lead text-muted mb-2">您已成功登录</p>

                        @* 登出按钮 *@
                        <a href="/Account/Logout" class="btn btn-outline-secondary mb-4">
                            <i class="fa-solid fa-right-from-bracket me-1"></i>
                            <span>@L["Logout"]</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>